#!/bin/sh
env_file="$HOME/.config/environment.d/90-pi-agent.conf"
if [ -r "$env_file" ]; then
  set -a
  . "$env_file"
  set +a
fi

export XMODIFIERS="${XMODIFIERS:-@im=fcitx}"
export GTK_IM_MODULE="${GTK_IM_MODULE:-fcitx}"
export QT_IM_MODULE="${QT_IM_MODULE:-fcitx}"
export SDL_IM_MODULE="${SDL_IM_MODULE:-fcitx}"

log_dir="${XDG_RUNTIME_DIR:-/tmp}"
exec python3 -m czero_apps.main robot "$@" 2>>"$log_dir/zero-robot-crash.log"
